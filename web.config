<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="PythonHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <!--
      HttpPlatformHandler launches waitress on %HTTP_PLATFORM_PORT%.
      IIS proxies incoming requests to that port.

      UPDATE THE PATHS BELOW to match your server:
        - processPath: full path to python.exe in your venv
        - arguments:   full path to waitress-serve.exe + wsgi module
        - stdoutLogFile: where to write logs
    -->
    <httpPlatform processPath="D:\Projects\home_finder_agents_social\.venv\Scripts\python.exe"
                  arguments="D:\Projects\home_finder_agents_social\run_waitress.py --port=%HTTP_PLATFORM_PORT%"
                  stdoutLogEnabled="true"
                  stdoutLogFile="D:\Projects\home_finder_agents_social\logs\iis-stdout.log"
                  startupTimeLimit="60"
                  processesPerApplication="1">
      <environmentVariables>
        <environmentVariable name="PYTHONPATH" value="D:\Projects\home_finder_agents_social" />
      </environmentVariables>
    </httpPlatform>

    <!-- Prevent IIS from serving .py, .db, .env files directly -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment=".env" />
          <add segment="instance" />
          <add segment="__pycache__" />
          <add segment=".venv" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".py" allowed="false" />
          <add fileExtension=".pyc" allowed="false" />
          <add fileExtension=".db" allowed="false" />
          <add fileExtension=".sqlite" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <!-- Optional: serve static files directly from IIS for performance -->
    <!--
    <staticContent>
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>
    -->

  </system.webServer>
</configuration>
