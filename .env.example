# Charleston Home Finder — Environment Variables
# Copy this to .env and fill in your actual keys

SECRET_KEY=change-me-to-something-random

# ── RapidAPI ─────────────────────────────────────────────────────
# ONE key works for BOTH APIs:
#   1. "Realty in US" (Realtor.com data) — https://rapidapi.com/apidojo/api/realty-in-us
#   2. "US Property Data" (Zillow data)  — https://rapidapi.com/propertydata-propertydata-default/api/us-property-data
# Subscribe to BOTH free tiers, then paste your key below.
RAPIDAPI_KEY=your-rapidapi-key-here

# ── Anthropic API (AI Deal Analyst) ─────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
# Pay-per-use: ~$0.01-0.03 per listing analysis
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Scraper Schedule ─────────────────────────────────────────────
FETCH_INTERVAL_HOURS=6

# ── Email (for account verification & password reset) ────────────
# Gmail example: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_DEFAULT_SENDER=HomeFinder <you@gmail.com>
